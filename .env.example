# ============================================================
#  Homelab .env.example
#  Copy this file to .env and edit as needed.
#  All values here are safe defaults — the stack will run
#  as-is, but change passwords if exposing to the internet.
# ============================================================


# ─── General ─────────────────────────────────────────────────────────────────

TZ=America/New_York
PUID=1000
PGID=1000

# Base domain for all services (e.g. homelab.local or yourdomain.com)
# Used by Nginx Proxy Manager to route subdomains.
DOMAIN=localhost


# ─── NAS / Storage ───────────────────────────────────────────────────────────
# Leave these as-is if you have no NAS — services will use local Docker volumes.

NAS_IP=192.168.1.100
NAS_MEDIA_PATH=/volume1/media
NAS_MUSIC_PATH=/volume1/music
NAS_BOOKS_PATH=/volume1/books
NAS_PHOTOS_PATH=/volume1/photos
NAS_DOCUMENTS_PATH=/volume1/documents


# ─── AdGuard Home ────────────────────────────────────────────────────────────

ADGUARD_USERNAME=admin
ADGUARD_PASSWORD=changeme


# ─── Mealie ──────────────────────────────────────────────────────────────────

MEALIE_DB_PASSWORD=changeme
MEALIE_SECRET_KEY=changeme-replace-with-random-string


# ─── Paperless-NGX ───────────────────────────────────────────────────────────

PAPERLESS_DB_PASSWORD=changeme
PAPERLESS_SECRET_KEY=changeme-replace-with-random-string
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme


# ─── Immich ──────────────────────────────────────────────────────────────────

IMMICH_DB_PASSWORD=changeme
IMMICH_DB_USERNAME=immich
IMMICH_DB_NAME=immich


# ─── n8n ─────────────────────────────────────────────────────────────────────

N8N_ENCRYPTION_KEY=changeme-replace-with-random-string


# ─── Koel ────────────────────────────────────────────────────────────────────

KOEL_DB_PASSWORD=changeme


# ─── Metabase ────────────────────────────────────────────────────────────────

METABASE_DB_PASSWORD=changeme


# ─── Pastefy ─────────────────────────────────────────────────────────────────

PASTEFY_DB_PASSWORD=changeme


# ─── NocoDB ──────────────────────────────────────────────────────────────────

NOCODB_DB_PASSWORD=changeme


# ─── Homepage widget API keys ─────────────────────────────────────────────────
# Optional — leave blank to disable widgets. Fill in after services are running.

HOMEPAGE_VAR_JELLYFIN=
HOMEPAGE_VAR_JELLYSEER=
HOMEPAGE_VAR_ADGUARD_USERNAME=admin
HOMEPAGE_VAR_ADGUARD_PASSWORD=changeme
HOMEPAGE_VAR_PORTAINER_KEY=
